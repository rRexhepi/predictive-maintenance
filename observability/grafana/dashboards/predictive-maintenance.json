{
  "uid": "predictive-maintenance",
  "title": "Predictive Maintenance API — Serving Health & Drift",
  "tags": ["predictive-maintenance", "ml", "serving"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "refresh": "15s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Requests per minute",
      "gridPos": {"x": 0, "y": 0, "w": 6, "h": 5},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "sum(rate(pm_predictions_total[5m])) * 60", "refId": "A"}
      ],
      "fieldConfig": {"defaults": {"unit": "reqps", "decimals": 1}},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "value", "graphMode": "area"}
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Mean predicted RUL",
      "gridPos": {"x": 6, "y": 0, "w": 6, "h": 5},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "sum(rate(pm_predicted_rul_sum[5m])) / clamp_min(sum(rate(pm_predicted_rul_count[5m])), 1)",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "none", "decimals": 1}},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}}
    },
    {
      "id": 3,
      "type": "stat",
      "title": "p99 latency",
      "gridPos": {"x": 12, "y": 0, "w": 6, "h": 5},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(pm_prediction_latency_seconds_bucket[5m])))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 3,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 0.05},
              {"color": "red", "value": 0.25}
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Max feature drift (PSI)",
      "gridPos": {"x": 18, "y": 0, "w": 6, "h": 5},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "max(pm_feature_drift_psi)", "refId": "A"}],
      "fieldConfig": {
        "defaults": {
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 0.1},
              {"color": "red", "value": 0.25}
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Requests / minute",
      "gridPos": {"x": 0, "y": 5, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "sum(rate(pm_predictions_total[1m])) * 60",
          "legendFormat": "requests/min",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "reqps"}}
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Prediction latency (p50 / p95 / p99)",
      "gridPos": {"x": 12, "y": 5, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(pm_prediction_latency_seconds_bucket[5m])))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(pm_prediction_latency_seconds_bucket[5m])))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(pm_prediction_latency_seconds_bucket[5m])))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "s"}}
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Feature drift (PSI) — alert threshold 0.25",
      "gridPos": {"x": 0, "y": 13, "w": 24, "h": 9},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "pm_feature_drift_psi",
          "legendFormat": "{{feature}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {"drawStyle": "line", "lineWidth": 2},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 0.1},
              {"color": "red", "value": 0.25}
            ]
          }
        }
      },
      "options": {
        "legend": {"displayMode": "table", "placement": "right", "calcs": ["lastNotNull", "max"]}
      }
    },
    {
      "id": 8,
      "type": "table",
      "title": "Loaded model (from /metrics model_info)",
      "gridPos": {"x": 0, "y": 22, "w": 24, "h": 5},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "pm_model_info",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ],
      "options": {"showHeader": true}
    }
  ]
}
